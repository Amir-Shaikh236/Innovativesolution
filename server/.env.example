# Database Configuration
MONGODB_URI=your_mongodb_connection_string

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend/Backend URLs - Update these for your local setup
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@yourapp.com

# File Upload
MAX_FILE_SIZE=52428800

# Session
SESSION_SECRET=your-session-secret-key

# Note: In development, CORS automatically allows any localhost/127.0.0.1 with any port
# No need to manually configure CORS origins for local development